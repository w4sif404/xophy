#!/usr/bin/env python3

import os
import dns.resolver
from concurrent.futures import ThreadPoolExecutor, as_completed

# =========================
# CONFIG
# =========================
WORDLIST = "wordlists/subdomains.txt"   # adjust path if needed
THREADS = 50
TIMEOUT = 2.0


# =========================
# DNS Resolver
# =========================
def resolve_subdomain(subdomain):
    try:
        dns.resolver.resolve(subdomain, "A", lifetime=TIMEOUT)
        return subdomain
    except Exception:
        return None


# =========================
# Output Formatter
# =========================
def print_subdomains(subdomains):
    print("=" * 40)
    print("[ Subdomain Enumeration ]")
        futures = [executor.submit(resolve_subdomain, s) for s in subs]
        for future in as_completed(futures):
            result = future.result()
            if result:
                found.append(result)

    # Remove duplicates & sort
    found = sorted(set(found))

    # Print only if NOT silent
    if found and not silent:
        print_subdomains(found)

    return found
